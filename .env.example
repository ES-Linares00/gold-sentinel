# .env.example — GOLD-SENTINEL
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al control de versiones.

# ─── APIs de Noticias (uso futuro en NewsAgent) ───────────────────────────
NEWSAPI_KEY=your_newsapi_key_here
ALPHAVANTAGE_KEY=your_alphavantage_key_here

# ─── Configuración general ────────────────────────────────────────────────
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
REQUEST_DELAY_SEC=1.0     # Delay mínimo entre peticiones a la misma fuente
